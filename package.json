{
  "name": "sophie-keep",
  "version": "1.0.0",
  "private": true,
  "description": "Household inventory management — responsive web app for a single household on its LAN.",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "npm-run-all -p dev:api dev:web",
    "dev:api": "npm -w @sophie/api run dev",
    "dev:web": "npm -w @sophie/web run dev",
    "build": "npm -w @sophie/shared run build && npm -w @sophie/web run build && npm -w @sophie/api run build",
    "start": "node packages/api/dist/index.js",
    "seed": "npm -w @sophie/api run seed",
    "test": "npm -ws --if-present run test",
    "typecheck": "npm -ws --if-present run typecheck"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
