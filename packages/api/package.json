{
  "name": "@sophie/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p . && node -e \"const fs=require('node:fs'),p=require('node:path');const src='src/db/migrations',dst='dist/db/migrations';fs.mkdirSync(dst,{recursive:true});for(const f of fs.readdirSync(src))if(f.endsWith('.sql'))fs.copyFileSync(p.join(src,f),p.join(dst,f));\"",
    "start": "node dist/index.js",
    "seed": "tsx src/scripts/seed.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/multipart": "^8.3.0",
    "@fastify/static": "^7.0.4",
    "@sophie/shared": "*",
    "better-sqlite3": "^11.5.0",
    "fastify": "^4.28.1",
    "file-type": "^19.6.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "pino-roll": "^2.0.0",
    "sharp": "^0.33.5",
    "tar-stream": "^3.1.7",
    "ulid": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.9.0",
    "@types/tar-stream": "^3.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  }
}
