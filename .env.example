# Docker Compose project name — used as a prefix for container, volume, and network names.
# Change this if you run multiple instances on the same host.
COMPOSE_PROJECT_NAME=sophie

# ── App ────────────────────────────────────────────────────────────────────────
# Host port the app is published on.
APP_PORT=3000

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=sophie
POSTGRES_PASSWORD=sophie
POSTGRES_DB=sophie
# Host port to publish the Postgres port on (useful for direct DB access / migrations).
# Leave empty or remove the port mapping from docker-compose.infra.yml to not expose it.
POSTGRES_PORT=5432

# ── MinIO ──────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=sophie
MINIO_ROOT_PASSWORD=sophiepass
MINIO_BUCKET=sophie-photos
# Host ports for MinIO S3 API and web console.
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
